{"$schema":"http://json-schema.org/draft-07/schema#","title":"Signal","type":"object",
 "required":["event_id","mode","p","confidence","reasons"],
 "properties":{"event_id":{"type":"string"},
  "mode":{"type":"string","enum":["PERFORMANCE","TRANSACTION","COGNITIVE_HONESTY","MIXED"]},
  "p":{"type":"object","description":"Softmax probability distribution over modes"},
  "confidence":{"type":"number","minimum":0,"maximum":1},
  "reasons":{"type":"array","items":{"type":"string"}}}}
