{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "http://signal-agent.ai/schemas/constraint-rule-v1.json",
  "type": "object",
  "properties": {
    "constraint_id": { "type": "string", "pattern": "^[A-Z0-9_]+$" },
    "scope": { "type": "string", "enum": ["GLOBAL", "DOMAIN", "TASK", "SESSION", "EMERGENCY"] },
    "intent": { "type": "string" },

    "trigger": {
      "type": "object",
      "properties": {
        "capability_id": { "type": ["string", "null"] },
        "risk_tier": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "ANY"] }
      },
      "additionalProperties": false
    },

    "predicate": {
      "type": "object",
      "description": "Structured DSL. No eval. Operators: AND, OR, NOT, EQ, GT, LT, IN, MATCHES"
    },

    "rule_type": { "type": "string", "enum": ["ALLOW", "DENY", "REQUIRE_APPROVAL", "LIMIT"] },
    "parameters": { "type": "object" },

    "enforcement_action": { "type": "string", "enum": ["BLOCK", "ESCALATE", "LOG_ONLY"] },
    "audit_event": { "type": "string" },
    "rollback_behavior": { "type": "string", "enum": ["ABORT", "RETRY", "COMPENSATE"] }
  },
  "required": ["constraint_id", "scope", "intent", "rule_type"],
  "additionalProperties": false
}
